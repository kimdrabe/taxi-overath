---

const contactInfo = [
  {
    label: 'Telefon',
    value: '+49 2206 9090990',
    href: 'tel:+4922069090990',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>'
  },
  {
    label: 'E-Mail',
    value: 'info@taxi-overath.de',
    href: 'mailto:info@taxi-overath.de',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>'
  },
];
---

<section id="contact" class="relative py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-taxi-yellow text-sm font-semibold tracking-widest uppercase">Kontakt</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3 mb-4">Wir sind fur Sie da</h2>
      <p class="text-white/50 max-w-lg mx-auto">
        Rufen Sie uns an oder schreiben Sie uns - wir antworten schnell!
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8">
      <div class="lg:col-span-2 space-y-6">
        {contactInfo.map((c) => (
          <div class="bg-taxi-card/60 backdrop-blur-sm border border-taxi-border rounded-2xl p-6 flex items-start gap-4 hover:border-taxi-yellow/30 transition">
            <div class="bg-taxi-yellow/10 text-taxi-yellow rounded-xl p-3 flex-shrink-0" set:html={c.icon} />
            <div>
              <p class="font-semibold mb-1">{c.label}</p>
              {c.href ? (
                <a href={c.href} class="text-white/60 hover:text-taxi-yellow transition">{c.value}</a>
              ) : (
                <p class="text-white/60">{c.value}</p>
              )}
            </div>
          </div>
        ))}
        <a href="tel:+4922069090990" class="flex items-center justify-center gap-2 rounded-xl bg-taxi-yellow px-6 py-4 text-base font-bold text-black shadow-lg shadow-taxi-yellow/25 hover:bg-taxi-yellow-hover transition-all duration-200 hover:scale-[1.02] active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +49 2206 9090990
        </a>
      </div>

      <div class="lg:col-span-3">
        <form netlify name="kontakt" method="POST" class="bg-taxi-card/60 backdrop-blur-sm border border-taxi-border rounded-2xl p-8 space-y-5">
          <input type="hidden" name="form-name" value="kontakt" />
          <div>
            <label for="name" class="block text-sm font-medium text-white/70 mb-2">Name *</label>
            <input type="text" id="name" name="name" required class="w-full bg-taxi-dark border border-taxi-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-taxi-yellow/50 focus:ring-1 focus:ring-taxi-yellow/20 transition" placeholder="Ihr Name" />
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="phone" class="block text-sm font-medium text-white/70 mb-2">Telefon *</label>
              <input type="tel" id="phone" name="phone" required class="w-full bg-taxi-dark border border-taxi-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-taxi-yellow/50 focus:ring-1 focus:ring-taxi-yellow/20 transition" placeholder="Ihre Telefonnummer" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white/70 mb-2">E-Mail</label>
              <input type="email" id="email" name="email" class="w-full bg-taxi-dark border border-taxi-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-taxi-yellow/50 focus:ring-1 focus:ring-taxi-yellow/20 transition" placeholder="Ihre E-Mail" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-white/70 mb-2">Nachricht *</label>
            <textarea id="message" name="message" rows="4" required class="w-full bg-taxi-dark border border-taxi-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-taxi-yellow/50 focus:ring-1 focus:ring-taxi-yellow/20 transition resize-none" placeholder="Wo soll es hingehen? Wann? Wie viele Personen?"></textarea>
          </div>
          <button type="submit" class="w-full rounded-xl bg-taxi-yellow px-6 py-4 text-base font-bold text-black hover:bg-taxi-yellow-hover transition-all duration-200 hover:scale-[1.02] active:scale-95">
            Nachricht senden
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
