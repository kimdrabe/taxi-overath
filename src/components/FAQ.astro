---

const faqs = [
  {
    q: 'Was kostet eine Fahrt mit Taxi Overath?',
    a: 'Der Fahrpreis richtet sich nach der offiziellen Taxitarifverordnung. Sie zahlen einen Grundpreis zzgl. Kilometerpreis. Gerne erstellen wir Ihnen vorab einen kostenlosen Festpreis für Ihre Fahrt – einfach anrufen!'
  },
  {
    q: 'Sind Krankentransporte möglich?',
    a: 'Ja, wir führen Krankentransporte und Dialysefahrten durch. Unsere Fahrer sind entsprechend geschult. Fahrten können auch regelmäßig wiederkehrend gebucht werden.'
  },
  {
    q: 'Gibt es Flughafentransfers?',
    a: 'Selbstverständlich! Wir fahren Sie zuverlässig zu allen Flughäfen (Köln/Bonn, Düsseldorf, Frankfurt). Auch mit Großgepäck – wir helfen Ihnen gerne.'
  },
  {
    q: 'Wie kurzfristig kann ich buchen?',
    a: 'In der Regel innerhalb weniger Minuten. Dank unserer 24/7-Erreichbarkeit sind Sie auch spontan flexibel. Für Planungssicherheit empfehlen wir eine Vorbuchung.'
  }
];
---

<section id="faq" class="relative py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-taxi-yellow text-sm font-semibold tracking-widest uppercase">FAQ</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3 mb-4">Häufig gestellte Fragen</h2>
    </div>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="group bg-taxi-card/40 backdrop-blur-sm border border-taxi-border rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer text-white/90 font-medium hover:text-taxi-yellow transition list-none">
            <span>{faq.q}</span>
            <svg class="w-5 h-5 text-taxi-yellow shrink-0 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="px-5 pb-5 text-white/60 text-sm leading-relaxed">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
