---

const steps = [
  { num: '1', title: 'Anrufen', desc: 'Rufen Sie uns an - 24/7 sind wir für Sie da.', icon: 'phone' },
  { num: '2', title: 'Fahrt buchen', desc: 'Teilen Sie uns Ihr Ziel mit - wir kümmern uns um den Rest.', icon: 'edit' },
  { num: '3', title: 'Abgeholt werden', desc: 'Pünktlich und freundlich werden Sie abgeholt.', icon: 'car' },
  { num: '4', title: 'Entspannt ankommen', desc: 'Sicher und komfortabel ans Ziel - entspannt und pünktlich.', icon: 'flag' }
];

const icons: Record<string, string> = {
  phone: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  edit: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',
  car: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.3-1.4.7l-1.5 2.8c-.1.2-.1.4-.1.7V17c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>',
  flag: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>'
};
---

<section id="how-it-works" class="relative py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-taxi-yellow text-sm font-semibold tracking-widest uppercase">So einfach geht's</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3 mb-4">In 4 Schritten ans Ziel</h2>
    </div>
    <div class="grid sm:grid-cols-4 gap-8 relative">
      <div class="hidden sm:block absolute top-12 left-[12%] right-[12%] h-0.5 bg-gradient-to-r from-taxi-yellow/50 via-taxi-yellow/30 to-transparent" />
      {steps.map((s) => (
        <div class="text-center relative">
          <div class="w-24 h-24 mx-auto mb-5 rounded-full bg-taxi-card border border-taxi-border flex items-center justify-center relative z-10">
            <span class="absolute -top-1 -right-1 w-8 h-8 rounded-full bg-taxi-yellow text-black text-sm font-bold flex items-center justify-center">{s.num}</span>
            <div class="text-taxi-yellow" set:html={icons[s.icon]} />
          </div>
          <h3 class="text-lg font-semibold mb-2">{s.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
